---

<Layout metadata={metadata}>
  <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=69f69bc36a8a0bd941af5f2d&product=sop' async='async'></script>
  <!-- Hero Widget ******************* -->

  <Hero
